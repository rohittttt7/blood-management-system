@model BloodBankManagementSystem.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="container py-5">
    <div class="row justify-content-center animate-fadeInUp">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-custom">
                <div class="card-header bg-gradient-primary text-white text-center py-4">
                    <i class="fas fa-sign-in-alt fa-3x mb-3"></i>
                    <h3 class="mb-0 fw-bold">Welcome Back</h3>
                    <p class="mb-0 opacity-75">Login to your account</p>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger rounded-custom" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label">
                                <i class="fas fa-envelope text-danger me-2"></i>Email Address
                            </label>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label">
                                <i class="fas fa-lock text-danger me-2"></i>Password
                            </label>
                            <input asp-for="Password" class="form-control form-control-lg" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label">
                                    Keep me signed in
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mb-4">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>Login
                            </button>
                        </div>

                        <div class="text-center">
                            <p class="text-muted mb-0">
                                Don't have an account? 
                                <a asp-action="Register" class="text-danger fw-bold text-decoration-none">
                                    Register here <i class="fas fa-arrow-right"></i>
                                </a>
                            </p>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="alert alert-info rounded-custom mb-0" role="alert">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-info-circle fa-2x me-3 mt-1"></i>
                            <div>
                                <strong class="d-block mb-2">Default Admin Credentials:</strong>
                                <div class="mb-1">
                                    <i class="fas fa-envelope me-2"></i>
                                    <code class="bg-white px-2 py-1 rounded">admin@bloodbank.com</code>
                                </div>
                                <div>
                                    <i class="fas fa-key me-2"></i>
                                    <code class="bg-white px-2 py-1 rounded">Admin@123</code>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Benefits Section -->
            <div class="mt-4">
                <div class="card shadow-custom">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3 text-center">
                            <i class="fas fa-star text-warning me-2"></i>Why Login?
                        </h6>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-center">
                                    <i class="fas fa-hand-holding-heart fa-2x text-danger mb-2"></i>
                                    <small class="d-block">Donate Blood</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center">
                                    <i class="fas fa-search fa-2x text-primary mb-2"></i>
                                    <small class="d-block">Request Blood</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center">
                                    <i class="fas fa-history fa-2x text-success mb-2"></i>
                                    <small class="d-block">Track History</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center">
                                    <i class="fas fa-tint fa-2x text-info mb-2"></i>
                                    <small class="d-block">Check Availability</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

