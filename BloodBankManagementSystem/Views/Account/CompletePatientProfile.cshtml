@{
    ViewData["Title"] = "Complete Patient Profile";
    var userId = ViewBag.UserId;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-danger text-white">
                <h3 class="mb-0"><i class="fas fa-user-injured"></i> Complete Patient Profile</h3>
            </div>
            <div class="card-body">
                <form asp-action="CompletePatientProfile" asp-route-userId="@userId" method="post">
                    <div class="mb-3">
                        <label for="bloodGroup" class="form-label">Blood Group</label>
                        <select name="bloodGroup" id="bloodGroup" class="form-select" required>
                            <option value="">Select Blood Group</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="age" class="form-label">Age</label>
                        <input type="number" name="age" id="age" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="medicalCondition" class="form-label">Medical Condition</label>
                        <textarea name="medicalCondition" id="medicalCondition" class="form-control" rows="3"></textarea>
                        <small class="form-text text-muted">Any existing medical conditions</small>
                    </div>

                    <div class="mb-3">
                        <label for="doctorReference" class="form-label">Doctor Reference (Name & Contact)</label>
                        <textarea name="doctorReference" id="doctorReference" class="form-control" rows="2" placeholder="Doctor's name and phone/email"></textarea>
                        <small class="form-text text-muted">Provide your doctor's name and contact information for medical verification</small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-check"></i> Complete Registration
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
