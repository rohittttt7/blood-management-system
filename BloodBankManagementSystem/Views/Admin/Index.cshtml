@{
    ViewData["Title"] = "Operations Dashboard";
    var totalDonors = (int)(ViewBag.TotalDonors ?? 0);
    var totalPatients = (int)(ViewBag.TotalPatients ?? 0);
    var pendingRequests = (int)(ViewBag.PendingRequests ?? 0);
    var pendingDonors = (int)(ViewBag.PendingDonors ?? 0);
    var totalBloodUnits = (int)(ViewBag.TotalBloodUnits ?? 0);

    var activeCases = pendingRequests + pendingDonors;
    var totalUsers = totalDonors + totalPatients;
    var operationalRate = totalUsers > 0
        ? (int)Math.Round(((double)(totalUsers - activeCases) / totalUsers) * 100)
        : 100;

    string unitsBadgeClass = totalBloodUnits < 25 ? "bg-danger" : totalBloodUnits < 45 ? "bg-warning text-dark" : "bg-success";
}

<div class="animate-fadeInUp">
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h2 class="fw-bold mb-1">
                    <i class="fas fa-tachometer-alt text-danger"></i> Operations Control Center
                </h2>
                <p class="text-dark mb-0 fs-5">Manage donors, requests, inventory, and operations from one clear dashboard.</p>
            </div>
            <div class="text-muted fw-semibold">
                <i class="fas fa-clock"></i> @DateTime.Now.ToString("MMMM dd, yyyy - HH:mm")
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2">Total Donors</h6>
                        <h2 class="display-5 fw-bold mb-0">@totalDonors</h2>
                        <small>Registered donors</small>
                    </div>
                    <i class="fas fa-users fa-3x opacity-50"></i>
                </div>
                @if (pendingDonors > 0)
                {
                    <div class="mt-3 pt-3 border-top border-white border-opacity-25">
                        <small><i class="fas fa-clock"></i> @pendingDonors pending approval</small>
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-success text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2">Total Patients</h6>
                        <h2 class="display-5 fw-bold mb-0">@totalPatients</h2>
                        <small>Registered patients</small>
                    </div>
                    <i class="fas fa-user-injured fa-3x opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-warning text-dark">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2">Pending Requests</h6>
                        <h2 class="display-5 fw-bold mb-0">@pendingRequests</h2>
                        <small>Awaiting action</small>
                    </div>
                    <i class="fas fa-clock fa-3x opacity-50"></i>
                </div>
                @if (pendingRequests > 0)
                {
                    <div class="mt-3 pt-3 border-top border-dark border-opacity-25">
                        <small class="fw-semibold"><i class="fas fa-exclamation-triangle"></i> Needs quick response</small>
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-danger text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2">Blood Units</h6>
                        <h2 class="display-5 fw-bold mb-0">@totalBloodUnits</h2>
                        <small>Total available</small>
                    </div>
                    <i class="fas fa-tint fa-3x opacity-50"></i>
                </div>
                <div class="mt-3 pt-3 border-top border-white border-opacity-25">
                    <small class="fw-semibold">Stock Status: <span class="badge @unitsBadgeClass">@((totalBloodUnits < 25) ? "Low" : (totalBloodUnits < 45 ? "Moderate" : "Stable"))</span></small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-bolt"></i> Quick Actions</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <a asp-action="ManageDonors" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-user-check text-primary me-3"></i>
                                <strong>Manage Donors</strong>
                                <small class="text-muted ms-2">Review and approve donor registrations</small>
                            </div>
                            <span class="badge bg-warning text-dark rounded-pill">@pendingDonors Pending</span>
                        </a>

                        <a asp-action="BloodRequests" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-file-medical text-danger me-3"></i>
                                <strong>Blood Requests</strong>
                                <small class="text-muted ms-2">Process patient blood requests</small>
                            </div>
                            <span class="badge bg-warning text-dark rounded-pill">@pendingRequests Pending</span>
                        </a>

                        <a asp-action="BloodInventory" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-box text-info me-3"></i>
                                <strong>Blood Inventory</strong>
                                <small class="text-muted ms-2">Update stock levels</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>

                        <a asp-action="RecordDonation" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-plus-circle text-success me-3"></i>
                                <strong>Record Donation</strong>
                                <small class="text-muted ms-2">Add new donation entry</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>

                        <a asp-action="Reports" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-chart-bar text-primary me-3"></i>
                                <strong>View Reports</strong>
                                <small class="text-muted ms-2">Analyze operations summary</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light fw-bold text-dark">
                    <i class="fas fa-heartbeat text-danger"></i> System Health
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1 text-dark">
                            <span class="fw-semibold">Operational Efficiency</span>
                            <span class="fw-bold">@operationalRate%</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @operationalRate%"></div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1 text-dark">
                            <span class="fw-semibold">Pending Actions</span>
                            <span class="fw-bold">@activeCases</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-warning" role="progressbar" style="width: @(Math.Min(activeCases * 10, 100))%"></div>
                        </div>
                    </div>

                    <ul class="list-group list-group-flush small">
                        <li class="list-group-item d-flex justify-content-between align-items-center text-dark">
                            Pending Donor Verifications
                            <span class="badge bg-warning text-dark">@pendingDonors</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center text-dark">
                            Pending Blood Requests
                            <span class="badge bg-danger">@pendingRequests</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center text-dark">
                            Registered Users
                            <span class="badge bg-primary">@totalUsers</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="alert alert-info shadow-sm mb-0" role="alert">
                <h6 class="fw-bold mb-2"><i class="fas fa-info-circle"></i> Admin Tip</h6>
                <p class="mb-0">Handle emergency requests first and monitor low-stock blood groups each shift.</p>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-4">
            <a asp-action="BloodRequests" class="btn btn-outline-danger w-100 py-3 fw-semibold">
                <i class="fas fa-file-medical"></i> Open Request Queue
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="BloodInventory" class="btn btn-outline-primary w-100 py-3 fw-semibold">
                <i class="fas fa-box"></i> Update Inventory
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="Reports" class="btn btn-outline-success w-100 py-3 fw-semibold">
                <i class="fas fa-chart-line"></i> View Reports
            </a>
        </div>
    </div>
</div>
