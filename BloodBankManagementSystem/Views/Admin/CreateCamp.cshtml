@model BloodBankManagementSystem.Models.DonationCamp
@{
    ViewData["Title"] = "Create Donation Camp";
}

<h2><i class="fas fa-plus text-primary"></i> Create Donation Camp</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="CreateCamp" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CampName" class="form-label"></label>
                    <input asp-for="CampName" class="form-control" />
                    <span asp-validation-for="CampName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="CampDate" class="form-label"></label>
                    <input asp-for="CampDate" type="date" class="form-control" />
                    <span asp-validation-for="CampDate" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="StartTime" class="form-label"></label>
                    <input asp-for="StartTime" type="time" class="form-control" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="EndTime" class="form-label"></label>
                    <input asp-for="EndTime" type="time" class="form-control" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ExpectedDonors" class="form-label"></label>
                    <input asp-for="ExpectedDonors" class="form-control" min="0" />
                    <span asp-validation-for="ExpectedDonors" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create Camp
                </button>
                <a asp-action="DonationCamps" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}