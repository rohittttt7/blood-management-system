@model IEnumerable<BloodBankManagementSystem.Models.BloodRequest>
@{
    ViewData["Title"] = "Blood Requests";
}

<h2><i class="fas fa-file-medical"></i> Blood Requests</h2>
<hr />

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-danger">
            <tr>
                <th>Patient Name</th>
                <th>Blood Group</th>
                <th>Units Required</th>
                <th>Request Date</th>
                <th>Emergency</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model)
            {
                <tr class="@(request.IsEmergency ? "table-warning" : "")">
                    <td>@request.Patient?.User?.FullName</td>
                    <td><span class="badge bg-danger">@request.BloodGroup</span></td>
                    <td>@request.UnitsRequired</td>
                    <td>@request.RequestDate.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (request.IsEmergency)
                        {
                            <span class="badge bg-danger">URGENT</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Normal</span>
                        }
                    </td>
                    <td>@request.Reason</td>
                    <td>
                        @if (request.Status == "Pending")
                        {
                            <span class="badge bg-warning">@request.Status</span>
                        }
                        else if (request.Status == "Approved")
                        {
                            <span class="badge bg-success">@request.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@request.Status</span>
                        }
                    </td>
                    <td style="min-width: 240px;">
                        @if (request.Status == "Pending")
                        {
                            <form asp-action="ApproveRequest" asp-route-id="@request.RequestId" method="post" class="mb-2"
                                  onsubmit="return confirm('Approve this blood request?');">
                                <div class="input-group input-group-sm">
                                    <input type="text" name="remarks" class="form-control" placeholder="Remarks (optional)" />
                                    <button type="submit" class="btn btn-success">
                                        <i class="fas fa-check"></i> Approve
                                    </button>
                                </div>
                            </form>
                            <form asp-action="RejectRequest" asp-route-id="@request.RequestId" method="post"
                                  onsubmit="return confirm('Reject this blood request?');">
                                <div class="input-group input-group-sm">
                                    <input type="text" name="remarks" class="form-control" placeholder="Reason for rejection" required />
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fas fa-times"></i> Reject
                                    </button>
                                </div>
                            </form>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(request.AdminRemarks))
                            {
                                <small class="text-muted">@request.AdminRemarks</small>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No blood requests found.
    </div>
}
