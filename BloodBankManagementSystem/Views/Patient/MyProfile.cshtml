@model BloodBankManagementSystem.Models.Patient
@{
    ViewData["Title"] = "My Profile";
}

<h2><i class="fas fa-user text-danger"></i> Patient Profile</h2>
<hr />

@if (Model == null)
{
    <div class="alert alert-warning">Patient profile not found.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6"><strong>Name:</strong> @Model.User?.FullName</div>
                <div class="col-md-6"><strong>Email:</strong> @Model.User?.Email</div>
                <div class="col-md-4"><strong>Blood Group:</strong> @Model.BloodGroup</div>
                <div class="col-md-4"><strong>Age:</strong> @Model.Age</div>
                <div class="col-md-4"><strong>Registered:</strong> @Model.RegisteredDate.ToString("dd MMM yyyy")</div>
                <div class="col-12"><strong>Medical Condition:</strong> @Model.MedicalCondition</div>
            </div>
        </div>
    </div>
}