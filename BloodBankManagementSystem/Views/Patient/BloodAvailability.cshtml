@model IEnumerable<BloodBankManagementSystem.Models.BloodGroup>
@{
    ViewData["Title"] = "Blood Availability";
}

<h2><i class="fas fa-tint text-danger"></i> Blood Availability</h2>
<hr />

<div class="row g-3">
    @foreach (var group in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h4><span class="badge bg-danger">@group.BloodType</span></h4>
                    <h5 class="mt-2">@group.AvailableUnits Units</h5>
                    @if (group.AvailableUnits <= 3)
                    {
                        <span class="badge bg-warning text-dark">Low Stock</span>
                    }
                </div>
            </div>
        </div>
    }
</div>