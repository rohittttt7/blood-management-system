@model IEnumerable<BloodBankManagementSystem.Models.Donor>
@{
    ViewData["Title"] = "Search Donors";
    var selectedGroup = ViewBag.SelectedBloodGroup as string;
}

<h2><i class="fas fa-search text-danger"></i> Search Blood Donors</h2>
<hr />

<form asp-action="SearchDonors" method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Blood Group</label>
        <select name="bloodGroup" class="form-select">
            <option value="">All Groups</option>
            @foreach (var group in new[] { "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-" })
            {
                <option value="@group" selected="@(selectedGroup == group)">@group</option>
            }
        </select>
    </div>
    <div class="col-md-3 align-self-end">
        <button type="submit" class="btn btn-danger"><i class="fas fa-filter"></i> Filter</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No eligible donors found for the selected criteria.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-danger">
                <tr>
                    <th>Name</th>
                    <th>Blood Group</th>
                    <th>City</th>
                    <th>Phone</th>
                    <th>Last Donation</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var donor in Model)
                {
                    <tr>
                        <td>@donor.User?.FullName</td>
                        <td><span class="badge bg-danger">@donor.BloodGroup</span></td>
                        <td>@donor.User?.City</td>
                        <td>@donor.User?.PhoneNumber</td>
                        <td>@(donor.LastDonationDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                        <td>
                            @if (donor.IsEligible)
                            {
                                <span class="badge bg-success">Eligible</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Not Eligible</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}