@model IEnumerable<BloodBankManagementSystem.Models.BloodRequest>
@{
    ViewData["Title"] = "My Blood Requests";
}

<h2><i class="fas fa-list text-danger"></i> My Blood Requests</h2>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">You have not submitted any blood requests.</div>
    <a asp-action="RequestBlood" class="btn btn-danger">Create Request</a>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-danger">
                <tr>
                    <th>Date</th>
                    <th>Blood Group</th>
                    <th>Units</th>
                    <th>Emergency</th>
                    <th>Status</th>
                    <th>Admin Remarks</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr>
                        <td>@request.RequestDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge bg-danger">@request.BloodGroup</span></td>
                        <td>@request.UnitsRequired</td>
                        <td>
                            @if (request.IsEmergency)
                            {
                                <span class="badge bg-warning text-dark">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(request.Status == "Pending" ? "bg-warning text-dark" : request.Status == "Approved" ? "bg-success" : "bg-danger")">
                                @request.Status
                            </span>
                        </td>
                        <td>@request.AdminRemarks</td>
                        <td>
                            @if (request.Status == "Pending")
                            {
                                <form asp-action="CancelRequest" asp-route-id="@request.RequestId" method="post" onsubmit="return confirm('Cancel this request?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}