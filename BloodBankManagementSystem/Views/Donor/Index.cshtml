@{
    ViewData["Title"] = "Donor Dashboard";
    var donor = ViewBag.Donor as BloodBankManagementSystem.Models.Donor;
}

<h2><i class="fas fa-hand-holding-heart"></i> Donor Dashboard</h2>
<hr />

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-success text-white shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-tint"></i> Blood Group</h5>
                <h2>@donor?.BloodGroup</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-heart"></i> Total Donations</h5>
                <h2>@ViewBag.TotalDonations</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-calendar"></i> Last Donation</h5>
                <h6>@ViewBag.LastDonation</h6>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-clock"></i> Next Eligible</h5>
                <h6>@ViewBag.NextEligible</h6>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-info-circle"></i> Your Status</h5>
            </div>
            <div class="card-body">
                @if (donor?.Status == "Approved")
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> Your profile is <strong>Approved</strong>. You can donate blood!
                    </div>
                }
                else if (donor?.Status == "Pending")
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-clock"></i> Your profile is <strong>Pending</strong> admin approval.
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-times-circle"></i> Your profile has been <strong>Rejected</strong>.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-tasks"></i> Quick Actions</h5>
            </div>
            <div class="list-group list-group-flush">
                <a asp-action="MyProfile" class="list-group-item list-group-item-action">
                    <i class="fas fa-user"></i> View Profile
                </a>
                <a asp-action="DonationHistory" class="list-group-item list-group-item-action">
                    <i class="fas fa-history"></i> Donation History
                </a>
                <a asp-action="UpcomingCamps" class="list-group-item list-group-item-action">
                    <i class="fas fa-calendar-alt"></i> Upcoming Camps
                </a>
                <a asp-action="BloodAvailability" class="list-group-item list-group-item-action">
                    <i class="fas fa-tint"></i> Blood Availability
                </a>
            </div>
        </div>
    </div>
</div>
