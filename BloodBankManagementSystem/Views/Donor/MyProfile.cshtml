@model BloodBankManagementSystem.Models.Donor
@{
    ViewData["Title"] = "My Profile";
}

<h2><i class="fas fa-user text-danger"></i> Donor Profile</h2>
<hr />

@if (Model == null)
{
    <div class="alert alert-warning">Donor profile not found.</div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6"><strong>Name:</strong> @Model.User?.FullName</div>
                <div class="col-md-6"><strong>Email:</strong> @Model.User?.Email</div>
                <div class="col-md-4"><strong>Blood Group:</strong> @Model.BloodGroup</div>
                <div class="col-md-4"><strong>Age:</strong> @Model.Age</div>
                <div class="col-md-4"><strong>Weight:</strong> @Model.Weight kg</div>
                <div class="col-md-6"><strong>Status:</strong> @Model.Status</div>
                <div class="col-md-6"><strong>Eligible:</strong> @(Model.IsEligible ? "Yes" : "No")</div>
                <div class="col-md-6"><strong>Total Donations:</strong> @Model.TotalDonations</div>
                <div class="col-md-6"><strong>Last Donation:</strong> @(Model.LastDonationDate?.ToString("dd MMM yyyy") ?? "Never")</div>
                <div class="col-md-12"><strong>Medical History:</strong> @Model.MedicalHistory</div>
            </div>
        </div>
    </div>

    <a asp-action="UpdateProfile" class="btn btn-primary">
        <i class="fas fa-edit"></i> Update Profile
    </a>
}