@model IEnumerable<BloodBankManagementSystem.Models.DonationRecord>
@{
    ViewData["Title"] = "Donation History";
}

<h2><i class="fas fa-history text-danger"></i> Donation History</h2>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">You have no donation records yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-danger">
                <tr>
                    <th>Date</th>
                    <th>Blood Group</th>
                    <th>Units</th>
                    <th>Status</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DonationDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge bg-danger">@item.BloodGroup</span></td>
                        <td>@item.UnitsCollected</td>
                        <td><span class="badge bg-success">@item.Status</span></td>
                        <td>@item.Remarks</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}