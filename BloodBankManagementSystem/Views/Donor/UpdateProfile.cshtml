@model BloodBankManagementSystem.Models.Donor
@{
    ViewData["Title"] = "Update Profile";
}

<h2><i class="fas fa-edit text-primary"></i> Update Donor Profile</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="UpdateProfile" method="post">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Age</label>
                    <input name="age" type="number" min="18" max="65" class="form-control" value="@Model?.Age" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Weight (kg)</label>
                    <input name="weight" type="number" min="40" step="0.1" class="form-control" value="@Model?.Weight" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Medical History</label>
                    <textarea name="medicalHistory" class="form-control" rows="4">@Model?.MedicalHistory</textarea>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a asp-action="MyProfile" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>