@model IEnumerable<BloodBankManagementSystem.Models.BloodGroup>
@{
    ViewData["Title"] = "Blood Availability";
}

<h2><i class="fas fa-tint text-danger"></i> Blood Availability</h2>
<hr />

<div class="row g-3">
    @foreach (var bg in Model.OrderBy(b => b.BloodType))
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h4><span class="badge bg-danger">@bg.BloodType</span></h4>
                    <h5 class="mt-2">@bg.AvailableUnits Units</h5>
                    <small class="text-muted">Updated: @bg.LastUpdated.ToString("dd MMM yyyy HH:mm")</small>
                </div>
            </div>
        </div>
    }
</div>