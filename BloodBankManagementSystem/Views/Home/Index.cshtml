@model IEnumerable<BloodBankManagementSystem.Models.BloodGroup>
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section with Animation -->
<div class="jumbotron text-white p-5 rounded-custom shadow-custom mb-5 animate-fadeInUp">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-3 fw-bold mb-4">
                    <i class="fas fa-heartbeat blood-drop"></i> Blood Bank Management System
                </h1>
                <p class="lead mb-4" style="font-size: 1.3rem;">
                    Every blood donation is a gift of life. Join us in saving lives today!
                </p>
                <hr class="my-4 bg-white">
                <p class="mb-4" style="font-size: 1.1rem;">
                    Register as a donor or patient and be part of this noble cause.
                </p>
                <div class="mt-4">
                    <a class="btn btn-light btn-lg me-2 hover-zoom" asp-controller="Account" asp-action="Register" asp-route-type="donor" role="button">
                        <i class="fas fa-hand-holding-heart"></i> Register as Donor
                    </a>
                    <a class="btn btn-outline-light btn-lg hover-zoom" asp-controller="Account" asp-action="Register" asp-route-type="patient" role="button">
                        <i class="fas fa-hospital-user"></i> Register as Patient
                    </a>
                </div>
            </div>
            <div class="col-lg-4 text-center d-none d-lg-block">
                <i class="fas fa-hand-holding-heart" style="font-size: 10rem; opacity: 0.2;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Blood Availability Section with Enhanced Cards -->
<div class="container mb-5 animate-fadeInUp" style="animation-delay: 0.2s;">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold mb-3">
            <i class="fas fa-tint text-danger"></i> Current Blood Availability
        </h2>
        <p class="text-muted">Real-time blood stock information</p>
    </div>

    <div class="row g-4">
        @if (ViewBag.BloodGroups != null)
        {
            @foreach (var blood in (ViewBag.BloodGroups as IEnumerable<BloodBankManagementSystem.Models.BloodGroup>)!)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="blood-card">
                        <div class="blood-type mb-3">
                            <i class="fas fa-tint"></i> @blood.BloodType
                        </div>
                        <div class="mb-3">
                            <h3 class="display-6 fw-bold text-dark mb-0">@blood.AvailableUnits</h3>
                            <small class="text-muted">Units Available</small>
                        </div>
                        @if (blood.AvailableUnits < 5)
                        {
                            <span class="badge bg-danger animate-pulse">
                                <i class="fas fa-exclamation-triangle"></i> Critical Low
                            </span>
                        }
                        else if (blood.AvailableUnits < 10)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="fas fa-exclamation-circle"></i> Low Stock
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                <i class="fas fa-check-circle"></i> Available
                            </span>
                        }
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="fas fa-clock"></i> Updated: @blood.LastUpdated.ToString("MMM dd")
                            </small>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Features Section with Icons -->
<div class="container mb-5 animate-fadeInUp" style="animation-delay: 0.4s;">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold mb-3">Our Services</h2>
        <p class="text-muted">Comprehensive blood bank management solutions</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 hover-zoom">
                <div class="card-body text-center p-4">
                    <div class="mb-4">
                        <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center" 
                             style="width: 100px; height: 100px;">
                            <i class="fas fa-hand-holding-heart fa-3x text-danger"></i>
                        </div>
                    </div>
                    <h4 class="card-title fw-bold mb-3">Donate Blood</h4>
                    <p class="card-text text-muted">
                        Register as a donor and help save lives. Your donation can make a difference in someone's life!
                    </p>
                    <a asp-controller="Account" asp-action="Register" asp-route-type="donor" class="btn btn-outline-danger mt-3">
                        <i class="fas fa-arrow-right"></i> Register as Donor
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 hover-zoom">
                <div class="card-body text-center p-4">
                    <div class="mb-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center" 
                             style="width: 100px; height: 100px;">
                            <i class="fas fa-search fa-3x text-primary"></i>
                        </div>
                    </div>
                    <h4 class="card-title fw-bold mb-3">Request Blood</h4>
                    <p class="card-text text-muted">
                        Register as a patient and request blood when needed. Quick approval for emergency requests!
                    </p>
                    <a asp-controller="Account" asp-action="Register" asp-route-type="patient" class="btn btn-outline-primary mt-3">
                        <i class="fas fa-arrow-right"></i> Register as Patient
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 hover-zoom">
                <div class="card-body text-center p-4">
                    <div class="mb-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center" 
                             style="width: 100px; height: 100px;">
                            <i class="fas fa-calendar-alt fa-3x text-success"></i>
                        </div>
                    </div>
                    <h4 class="card-title fw-bold mb-3">Donation Camps</h4>
                    <p class="card-text text-muted">
                        Join our blood donation camps and be a part of community service. Save multiple lives at once!
                    </p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-success mt-3">
                        <i class="fas fa-arrow-right"></i> View Camps
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Statistics Section -->
<div class="container mb-5 animate-fadeInUp" style="animation-delay: 0.6s;">
    <div class="card shadow-custom">
        <div class="card-body p-5">
            <div class="row text-center g-4">
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card">
                        <i class="fas fa-users stat-icon text-primary"></i>
                        <h3 class="display-4 fw-bold text-primary mb-2">500+</h3>
                        <h5 class="text-muted mb-0">Registered Donors</h5>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card">
                        <i class="fas fa-heartbeat stat-icon text-danger"></i>
                        <h3 class="display-4 fw-bold text-danger mb-2">1000+</h3>
                        <h5 class="text-muted mb-0">Lives Saved</h5>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card">
                        <i class="fas fa-tint stat-icon text-info"></i>
                        <h3 class="display-4 fw-bold text-info mb-2">
                            @if(ViewBag.BloodGroups != null)
                            {
                                @((ViewBag.BloodGroups as IEnumerable<BloodBankManagementSystem.Models.BloodGroup>)!.Sum(b => b.AvailableUnits))
                            }
                        </h3>
                        <h5 class="text-muted mb-0">Blood Units</h5>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card">
                        <i class="fas fa-hospital stat-icon text-success"></i>
                        <h3 class="display-4 fw-bold text-success mb-2">50+</h3>
                        <h5 class="text-muted mb-0">Camps Organized</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action Section -->
<div class="container mb-5 animate-fadeInUp" style="animation-delay: 0.8s;">
    <div class="card bg-gradient-primary text-white shadow-custom">
        <div class="card-body p-5 text-center">
            <h2 class="display-5 fw-bold mb-4">Ready to Make a Difference?</h2>
            <p class="lead mb-4">Join thousands of donors who have already saved countless lives</p>
            <a class="btn btn-lg me-3 hover-zoom cta-action-btn" asp-controller="Account" asp-action="Register">
                <i class="fas fa-user-plus"></i> Register Today
            </a>
            <a class="btn btn-lg hover-zoom cta-action-btn" asp-controller="Home" asp-action="Contact">
                <i class="fas fa-phone"></i> Contact Us
            </a>
        </div>
    </div>
</div>
