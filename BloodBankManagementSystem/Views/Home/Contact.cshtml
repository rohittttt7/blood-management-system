@{
    ViewData["Title"] = "Contact Us";
}

<div class="container py-2">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 p-lg-5">
            <h2 class="fw-bold mb-2"><i class="fas fa-headset text-danger"></i> Contact & Support</h2>
            <p class="text-dark fs-5 mb-0">Need blood support, donor information, or emergency help? Reach us through the channels below.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Get In Touch</h4>

                    <div class="mb-3 fs-5">
                        <div class="fw-semibold"><i class="fas fa-map-marker-alt text-danger"></i> Address</div>
                        <div class="text-dark">123 Blood Bank Street, Medical District, City, State - 123456</div>
                    </div>

                    <div class="mb-3 fs-5">
                        <div class="fw-semibold"><i class="fas fa-phone text-danger"></i> Phone</div>
                        <div class="text-dark">+1 234 567 8900</div>
                    </div>

                    <div class="mb-3 fs-5">
                        <div class="fw-semibold"><i class="fas fa-envelope text-danger"></i> Email</div>
                        <div class="text-dark">info@bloodbank.com</div>
                    </div>

                    <div class="fs-5">
                        <div class="fw-semibold"><i class="fas fa-clock text-danger"></i> Working Hours</div>
                        <div class="text-dark">Monday - Saturday: 9:00 AM - 6:00 PM</div>
                        <div class="text-dark">Sunday: 10:00 AM - 4:00 PM</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="alert alert-danger shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-2"><i class="fas fa-ambulance"></i> 24/7 Emergency Helpline</h5>
                <h3 class="mb-1">+1 234 567 9999</h3>
                <p class="mb-0">For urgent blood requirements and emergency hospital support.</p>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Follow Us</h5>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-primary">
                    <i class="fab fa-facebook-f"></i> Facebook
                        </button>
                        <button type="button" class="btn btn-outline-info">
                    <i class="fab fa-twitter"></i> Twitter
                        </button>
                        <button type="button" class="btn btn-outline-danger">
                    <i class="fab fa-instagram"></i> Instagram
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
