@{
    ViewData["Title"] = "Contact Us";
}

<div class="container">
    <h2 class="text-center mb-4"><i class="fas fa-phone"></i> Contact Us</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <h4>Get In Touch</h4>
            <div class="card">
                <div class="card-body">
                    <p><i class="fas fa-map-marker-alt text-danger"></i> <strong>Address:</strong></p>
                    <p>123 Blood Bank Street, Medical District<br />City, State - 123456</p>

                    <p><i class="fas fa-phone text-danger"></i> <strong>Phone:</strong></p>
                    <p>+1 234 567 8900</p>

                    <p><i class="fas fa-envelope text-danger"></i> <strong>Email:</strong></p>
                    <p>info@bloodbank.com</p>

                    <p><i class="fas fa-clock text-danger"></i> <strong>Working Hours:</strong></p>
                    <p>Monday - Saturday: 9:00 AM - 6:00 PM<br />Sunday: 10:00 AM - 4:00 PM</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <h4>Emergency Contact</h4>
            <div class="alert alert-danger">
                <h5><i class="fas fa-ambulance"></i> 24/7 Emergency Helpline</h5>
                <h3>+1 234 567 9999</h3>
            </div>

            <h4 class="mt-4">Follow Us</h4>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-primary">
                    <i class="fab fa-facebook-f"></i> Facebook
                </button>
                <button type="button" class="btn btn-outline-info">
                    <i class="fab fa-twitter"></i> Twitter
                </button>
                <button type="button" class="btn btn-outline-danger">
                    <i class="fab fa-instagram"></i> Instagram
                </button>
            </div>
        </div>
    </div>
</div>
