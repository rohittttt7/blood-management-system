@{
    ViewData["Title"] = "About Us";
}

<div class="container">
    <h2 class="text-center mb-4"><i class="fas fa-info-circle"></i> About Blood Bank Management System</h2>
    <hr />

    <div class="row">
        <div class="col-md-12">
            <p class="lead text-center">
                We are dedicated to saving lives by connecting blood donors with those in need.
            </p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h4><i class="fas fa-bullseye"></i> Our Mission</h4>
            <p>
                To provide a reliable and efficient blood bank management system that ensures
                the availability of safe blood for patients in need while making it easy for
                donors to contribute to this noble cause.
            </p>
        </div>
        <div class="col-md-6">
            <h4><i class="fas fa-eye"></i> Our Vision</h4>
            <p>
                To create a world where no life is lost due to the unavailability of blood,
                and every blood donor is recognized and appreciated for their contribution.
            </p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <h4><i class="fas fa-star"></i> Why Choose Us?</h4>
            <ul class="list-group">
                <li class="list-group-item"><i class="fas fa-check text-success"></i> Easy Registration for Donors and Patients</li>
                <li class="list-group-item"><i class="fas fa-check text-success"></i> Real-time Blood Availability Information</li>
                <li class="list-group-item"><i class="fas fa-check text-success"></i> Quick Emergency Request Processing</li>
                <li class="list-group-item"><i class="fas fa-check text-success"></i> Organized Blood Donation Camps</li>
                <li class="list-group-item"><i class="fas fa-check text-success"></i> Secure and Efficient Management</li>
            </ul>
        </div>
    </div>
</div>
