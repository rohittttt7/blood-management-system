@{
    ViewData["Title"] = "About Us";
}

<div class="container py-2">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 p-lg-5">
            <h2 class="fw-bold mb-3"><i class="fas fa-info-circle text-danger"></i> About Blood Bank Management System</h2>
            <p class="lead fs-4 mb-0 text-dark">
                We help hospitals, patients, and donors connect faster so life-saving blood is available when it is needed most.
            </p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold"><i class="fas fa-bullseye text-danger"></i> Our Mission</h4>
                    <p class="fs-5 text-dark mb-0">
                        Provide a reliable and efficient blood bank platform that ensures safe blood availability,
                        simplifies donor contribution, and supports emergency medical care.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold"><i class="fas fa-eye text-danger"></i> Our Vision</h4>
                    <p class="fs-5 text-dark mb-0">
                        Build a future where no life is lost because of blood shortages and every donor is valued for their impact.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mt-4">
        <div class="card-body p-4">
            <h4 class="fw-bold mb-3"><i class="fas fa-star text-danger"></i> Why Choose Us?</h4>
            <div class="row g-3 fs-5">
                <div class="col-md-6"><i class="fas fa-check-circle text-success"></i> Easy donor and patient onboarding</div>
                <div class="col-md-6"><i class="fas fa-check-circle text-success"></i> Real-time blood stock visibility</div>
                <div class="col-md-6"><i class="fas fa-check-circle text-success"></i> Fast emergency request handling</div>
                <div class="col-md-6"><i class="fas fa-check-circle text-success"></i> Donation camp coordination</div>
                <div class="col-md-6"><i class="fas fa-check-circle text-success"></i> Secure role-based access</div>
                <div class="col-md-6"><i class="fas fa-check-circle text-success"></i> Transparent request tracking</div>
            </div>
        </div>
    </div>
</div>
