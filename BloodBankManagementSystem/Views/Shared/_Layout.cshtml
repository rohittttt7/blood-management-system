@using Microsoft.AspNetCore.Identity
@inject SignInManager<BloodBankManagementSystem.Models.ApplicationUser> SignInManager
@inject UserManager<BloodBankManagementSystem.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blood Bank Management System</title>

    <!-- Bootstrap CSS from CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />

    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            color: #212529;
            font-size: 1.03rem;
            line-height: 1.6;
        }

        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            letter-spacing: 0.2px;
        }

        .navbar {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%) !important;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

        .btn {
            border-radius: 25px;
            transition: all 0.3s ease;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .jumbotron {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            border-radius: 20px;
        }

        .blood-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
        }

        .blood-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

        .blood-type {
            font-size: 2.5rem;
            font-weight: bold;
            color: #dc3545;
        }

        .dashboard-card {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            color: white;
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

        .list-group-item {
            border-radius: 10px !important;
            margin-bottom: 0.5rem;
            transition: all 0.3s ease;
        }

        .list-group-item:hover {
            transform: translateX(10px);
            background-color: #f8d7da;
        }

        .table {
            background: white;
            border-radius: 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

        .table thead {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f8f9fa;
        }
    </style>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🩸</text></svg>">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-tint"></i> Blood Bank System
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="BloodRequests">Requests</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="BloodInventory">Inventory</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="ManageDonors">Donor Records</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="DonationRecords">Donations</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="DonationCamps">Camps</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="ManageUsers">Users</a>
                                </li>
                            }
                            else if (User.IsInRole("Employee"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Employee" asp-action="Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="BloodRequests">Requests</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="BloodInventory">Inventory</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="ManageDonors">Donor Records</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Admin" asp-action="DonationRecords">Donations</a>
                                </li>
                            }
                            else if (User.IsInRole("Donor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Donor" asp-action="Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Donor" asp-action="DonationHistory">Donation History</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Donor" asp-action="UpdateProfile">Update Profile</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Donor" asp-action="UpcomingCamps">Camps</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Donor" asp-action="BloodAvailability">Blood Availability</a>
                                </li>
                            }
                            else if (User.IsInRole("Patient"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Patient" asp-action="Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Patient" asp-action="RequestBlood">Request Blood</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user"></i> @User.Identity!.Name
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Operations Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageDonors">Manage Donor Records</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="BloodRequests">Blood Requests</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="BloodInventory">Blood Inventory</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="DonationRecords">Donation Records</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="DonationCamps">Donation Camps</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageUsers">Manage Users</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Reports">Reports</a></li>
                                    }
                                    else if (User.IsInRole("Employee"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Employee" asp-action="Dashboard">Employee Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageDonors">Donor Records</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="BloodRequests">Blood Requests</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="BloodInventory">Blood Inventory</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="DonationRecords">Donation Records</a></li>
                                    }
                                    else if (User.IsInRole("Donor"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Donor" asp-action="MyProfile">My Profile</a></li>
                                        <li><a class="dropdown-item" asp-controller="Donor" asp-action="DonationHistory">Donation History</a></li>
                                        <li><a class="dropdown-item" asp-controller="Donor" asp-action="UpdateProfile">Update Profile</a></li>
                                        <li><a class="dropdown-item" asp-controller="Donor" asp-action="UpcomingCamps">Upcoming Camps</a></li>
                                        <li><a class="dropdown-item" asp-controller="Donor" asp-action="BloodAvailability">Blood Availability</a></li>
                                    }
                                    else if (User.IsInRole("Patient"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Patient" asp-action="MyProfile">My Profile</a></li>
                                        <li><a class="dropdown-item" asp-controller="Patient" asp-action="MyRequests">My Requests</a></li>
                                        <li><a class="dropdown-item" asp-controller="Patient" asp-action="SearchDonors">Search Donors</a></li>
                                    }
                                    
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer mt-5">
        <div class="container py-4 py-lg-5">
            <div class="row g-4 align-items-start">
                <div class="col-lg-4 col-md-6">
                    <h5 class="app-footer-title"><i class="fas fa-tint me-2"></i>Blood Bank Management System</h5>
                    <p class="app-footer-text mb-0">Saving lives, one donation at a time.</p>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h5 class="app-footer-title">Quick Links</h5>
                    <ul class="list-unstyled app-footer-links mb-0">
                        <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-12">
                    <h5 class="app-footer-title">Contact</h5>
                    <p class="app-footer-text mb-2"><i class="fas fa-phone me-2"></i>+1 234 567 8900</p>
                    <p class="app-footer-text mb-0"><i class="fas fa-envelope me-2"></i>info@bloodbank.com</p>
                </div>
            </div>
            <hr class="app-footer-divider" />
            <div class="text-center app-footer-copy">
                &copy; 2026 - Blood Bank Management System - All Rights Reserved
            </div>
        </div>
    </footer>

    <!-- jQuery from CDN -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

    <!-- Bootstrap JS from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
