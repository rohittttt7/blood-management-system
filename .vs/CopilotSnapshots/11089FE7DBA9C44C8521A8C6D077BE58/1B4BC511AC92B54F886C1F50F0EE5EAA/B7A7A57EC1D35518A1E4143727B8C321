@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="animate-fadeInUp">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="fas fa-tachometer-alt text-danger"></i> Admin Dashboard
        </h2>
        <div class="text-muted">
            <i class="fas fa-clock"></i> @DateTime.Now.ToString("MMMM dd, yyyy - HH:mm")
        </div>
    </div>
    <hr class="mb-5" />

    <!-- Dashboard Statistics Cards -->
    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2 opacity-75">Total Donors</h6>
                        <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalDonors</h2>
                        <small class="opacity-75">Registered donors</small>
                    </div>
                    <div>
                        <i class="fas fa-users fa-3x opacity-25"></i>
                    </div>
                </div>
                @if (ViewBag.PendingDonors > 0)
                {
                    <div class="mt-3 pt-3 border-top border-white border-opacity-25">
                        <small><i class="fas fa-clock"></i> @ViewBag.PendingDonors pending approval</small>
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2 opacity-75">Total Patients</h6>
                        <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalPatients</h2>
                        <small class="opacity-75">Registered patients</small>
                    </div>
                    <div>
                        <i class="fas fa-user-injured fa-3x opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2 opacity-75">Pending Requests</h6>
                        <h2 class="display-4 fw-bold mb-0">@ViewBag.PendingRequests</h2>
                        <small class="opacity-75">Awaiting approval</small>
                    </div>
                    <div>
                        <i class="fas fa-clock fa-3x opacity-25"></i>
                    </div>
                </div>
                @if (ViewBag.PendingRequests > 0)
                {
                    <div class="mt-3 pt-3 border-top border-white border-opacity-25">
                        <small class="animate-pulse"><i class="fas fa-exclamation-triangle"></i> Requires attention</small>
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-danger">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-2 opacity-75">Blood Units</h6>
                        <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalBloodUnits</h2>
                        <small class="opacity-75">Total available</small>
                    </div>
                    <div>
                        <i class="fas fa-tint fa-3x opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-custom">
                <div class="card-header bg-gradient-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-bolt"></i> Quick Actions</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <a asp-action="ManageDonors" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-user-check text-primary me-3"></i>
                                <strong>Manage Donors</strong>
                                <small class="text-muted ms-2">Review and approve donor registrations</small>
                            </div>
                            @if (ViewBag.PendingDonors > 0)
                            {
                                <span class="badge bg-warning text-dark rounded-pill animate-pulse">
                                    @ViewBag.PendingDonors Pending
                                </span>
                            }
                            else
                            {
                                <i class="fas fa-chevron-right text-muted"></i>
                            }
                        </a>

                        <a asp-action="BloodRequests" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-file-medical text-danger me-3"></i>
                                <strong>Blood Requests</strong>
                                <small class="text-muted ms-2">Process patient blood requests</small>
                            </div>
                            @if (ViewBag.PendingRequests > 0)
                            {
                                <span class="badge bg-warning text-dark rounded-pill animate-pulse">
                                    @ViewBag.PendingRequests Pending
                                </span>
                            }
                            else
                            {
                                <i class="fas fa-chevron-right text-muted"></i>
                            }
                        </a>

                        <a asp-action="BloodInventory" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-box text-info me-3"></i>
                                <strong>Blood Inventory</strong>
                                <small class="text-muted ms-2">Manage blood stock levels</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>

                        <a asp-action="RecordDonation" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-plus-circle text-success me-3"></i>
                                <strong>Record New Donation</strong>
                                <small class="text-muted ms-2">Add new blood donation record</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>

                        <a asp-action="DonationCamps" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-calendar-alt text-warning me-3"></i>
                                <strong>Donation Camps</strong>
                                <small class="text-muted ms-2">Organize and manage blood camps</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>

                        <a asp-action="ManageUsers" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-users-cog text-secondary me-3"></i>
                                <strong>Manage Users</strong>
                                <small class="text-muted ms-2">Control user accounts and permissions</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>

                        <a asp-action="Reports" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-chart-bar text-primary me-3"></i>
                                <strong>View Reports</strong>
                                <small class="text-muted ms-2">Generate and view detailed reports</small>
                            </div>
                            <i class="fas fa-chevron-right text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="row g-4 mt-4">
        <div class="col-md-12">
            <div class="alert alert-info shadow-custom" role="alert">
                <div class="d-flex align-items-center">
                    <i class="fas fa-info-circle fa-2x me-3"></i>
                    <div>
                        <h5 class="alert-heading mb-1">Welcome to Admin Dashboard!</h5>
                        <p class="mb-0">You have full control over the Blood Bank Management System. Monitor activities and manage resources efficiently.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
