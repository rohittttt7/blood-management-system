@model IEnumerable<BloodBankManagementSystem.Models.BloodGroup>
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="jumbotron bg-danger text-white p-5 rounded">
    <h1 class="display-4"><i class="fas fa-heartbeat"></i> Welcome to Blood Bank Management System</h1>
    <p class="lead">Every blood donation is a gift of life. Join us in saving lives today!</p>
    <hr class="my-4 bg-white">
    <p>Register as a donor or patient and be part of this noble cause.</p>
    <div class="mt-4">
        <a class="btn btn-light btn-lg me-2" asp-controller="Account" asp-action="Register" role="button">
            <i class="fas fa-user-plus"></i> Register Now
        </a>
        <a class="btn btn-outline-light btn-lg" asp-controller="Account" asp-action="Login" role="button">
            <i class="fas fa-sign-in-alt"></i> Login
        </a>
    </div>
</div>

<!-- Blood Availability Section -->
<div class="row mt-5">
    <div class="col-md-12">
        <h2 class="text-center mb-4"><i class="fas fa-tint"></i> Current Blood Availability</h2>
        <div class="row">
            @if (ViewBag.BloodGroups != null)
            {
                @foreach (var blood in ViewBag.BloodGroups as IEnumerable<BloodBankManagementSystem.Models.BloodGroup>)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card text-center shadow-sm">
                            <div class="card-body">
                                <h3 class="card-title text-danger">@blood.BloodType</h3>
                                <h4 class="text-muted">@blood.AvailableUnits Units</h4>
                                @if (blood.AvailableUnits < 5)
                                {
                                    <span class="badge bg-warning text-dark">Low Stock</span>
                                }
                                else if (blood.AvailableUnits >= 10)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">Moderate</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="row mt-5 mb-5">
    <div class="col-md-12">
        <h2 class="text-center mb-4">Our Services</h2>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="fas fa-hand-holding-heart fa-3x text-danger mb-3"></i>
                <h5 class="card-title">Donate Blood</h5>
                <p class="card-text">Register as a donor and help save lives. Your donation can make a difference!</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="fas fa-search fa-3x text-danger mb-3"></i>
                <h5 class="card-title">Request Blood</h5>
                <p class="card-text">Register as a patient and request blood when needed. We're here to help!</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="fas fa-calendar-alt fa-3x text-danger mb-3"></i>
                <h5 class="card-title">Donation Camps</h5>
                <p class="card-text">Join our blood donation camps and be a part of community service.</p>
            </div>
        </div>
    </div>
</div>

<!-- Statistics Section -->
<div class="row bg-light p-4 rounded mb-5">
    <div class="col-md-3 text-center">
        <i class="fas fa-users fa-3x text-danger mb-2"></i>
        <h3>Donors</h3>
        <p class="text-muted">Registered donors ready to help</p>
    </div>
    <div class="col-md-3 text-center">
        <i class="fas fa-heartbeat fa-3x text-danger mb-2"></i>
        <h3>Patients</h3>
        <p class="text-muted">Lives touched through blood donation</p>
    </div>
    <div class="col-md-3 text-center">
        <i class="fas fa-tint fa-3x text-danger mb-2"></i>
        <h3>Blood Units</h3>
        <p class="text-muted">Units collected and distributed</p>
    </div>
    <div class="col-md-3 text-center">
        <i class="fas fa-hospital fa-3x text-danger mb-2"></i>
        <h3>Camps Organized</h3>
        <p class="text-muted">Blood donation camps conducted</p>
    </div>
</div>
